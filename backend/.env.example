# ============================================================
# Internal Knowledge Hub — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Google API (required) ---
# Used for: Gemini Flash (LLM), text-embedding-004 (embeddings), vision parsing
GEMINI_API_KEY=your_gemini_api_key_here

# --- Auth (required in production) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_generate_random_string

# --- Database (set automatically by docker-compose) ---
POSTGRES_URI=postgresql+asyncpg://morphik:morphik@postgres:5432/morphik

# --- Redis (set automatically by docker-compose) ---
REDIS_URL=redis://redis:6379/0

# --- Optional: OpenAI fallback ---
# OPENAI_API_KEY=sk-...

# --- Optional: Anthropic fallback ---
# ANTHROPIC_API_KEY=sk-ant-...
